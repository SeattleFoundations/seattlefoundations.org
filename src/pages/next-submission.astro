---
import BaseLayout from "@layouts/BaseLayout.astro";
import { NextSubmissionForm } from "@components/Forms/NextSubmissionForm";

const meta = {
	title: "Submit a Problem | Foundations Next",
	description:
		"Submit a real business problem to Foundations Next. If the problem is compelling and worth solving, Foundations may help solve it for free.",
};
---

<BaseLayout {...meta}>
	<section class="site-container">
		<div
			class="overflow-x-clip bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat pt-24 pb-12 text-center md:pt-32 md:pb-16 dark:bg-none"
		>
			<div class="mx-auto flex max-w-[950px] flex-col justify-center">
				<img
					src="/foundations-next-logo-animated-indigo-slide.svg"
					alt="Foundations Next"
					class="mx-auto mb-6 h-auto w-full max-w-[20rem] dark:hidden md:max-w-[24rem]"
				/>
				<img
					src="/foundations-next-logo-darkmode-animated.svg"
					alt="Foundations Next"
					class="mx-auto mb-6 hidden h-auto w-full max-w-[20rem] dark:block md:max-w-[24rem]"
				/>
				<h1 class="h1">Submit a Real Problem</h1>
				<p class="description mx-auto mt-4 max-w-3xl text-lg md:text-xl">
					We&apos;re not asking you to pitch a startup. We&apos;re asking you to describe a painful,
					important business problem that actually exists inside a non-technical industry.
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-3xl pb-16 md:pb-24">
			<div class="bg-card text-card-foreground rounded-xl border border-purple-200 p-6 shadow-sm md:p-8 dark:border-purple-900">
				<NextSubmissionForm client:load />
			</div>
		</div>
	</section>
</BaseLayout>
