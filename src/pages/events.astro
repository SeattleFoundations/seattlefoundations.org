---
/**
 * Events page that fetches and displays upcoming events from the API
 */

import { Icon } from "astro-icon/components";

// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

const stagingEventsPayload = {
	success: true,
	upcomingPrivateEventCount: 2,
	events: [
		{
			id: "eaf04eb6-9445-489c-8902-8ba04c9d6347",
			name: "Seattle Startup Summit, 2026",
			description: null,
			date: "2026-03-31T07:00:00.000Z",
			startTime: "14:00:00",
			endTime: "17:00:00",
			link: "https://lu.ma/seattle-startup-summit",
			imageUrl:
				"https://images.lumacdn.com/event-covers/27/a2122637-dcf3-40fb-91fc-d8e8a83afc89.png",
			location: null,
			hostName: "Yujian Tang, Anna Hong, OSS4AI, B.E.L.L.E, Oli Dinov, Lindsay Randall, JP Morgan, Sean",
			source: "luma",
		},
		{
			id: "803843e7-dff5-4b8e-9f4a-ca5955747f47",
			name: "NVIDIA Developer Meetup | Seattle Edition",
			description: null,
			date: "2026-03-31T07:00:00.000Z",
			startTime: "18:00:00",
			endTime: "21:00:00",
			link: "https://lu.ma/NVIDIASeattlemeetup",
			imageUrl:
				"https://images.lumacdn.com/event-covers/gx/e4aa6021-40b1-4db6-9dfe-8317bce3864b.png",
			location: null,
			hostName: "JoAnn Peach, Yujian Tang",
			source: "luma",
		},
		{
			id: "3de477b6-9a6a-4eea-b2fe-a7cb15a6ff73",
			name: "AI Dev Tool Track - Seattle Meetup - April 13th, 2026",
			description:
				"AI Tinkerers: Dev Tools is a monthly session for the AI-first builder: lightning demos, live code audits, and rapid-fire stack debates on the IDEs, the .md's, and the agents. Brought to you by Actual AI.",
			date: "2026-04-12T07:00:00.000Z",
			startTime: "18:00:00",
			endTime: "21:00:00",
			link: "https://seattle.aitinkerers.org/p/ai-dev-tool-track-seattle-meetup-april-13th-2026",
			imageUrl: "https://sloppy-joe-app.imgix.net/integrated_text_banner/_U7DI60qrPbE.jpg?fm=jpg",
			location: null,
			hostName: "AI Tinkerers Seattle",
			source: "aitinkerers",
		},
		{
			id: "eff286c3-38c7-41cb-938b-6777b4f7d40c",
			name: "AI Tinkerers: Dev Tools Track",
			description:
				"AI Tinkerers: Dev Tools is a monthly session for the AI-first builder: lightning demos, live code audits, and rapid-fire stack debates on the IDEs, the .md's, and the agents. Brought to you by Actual AI.",
			date: "2026-04-13T07:00:00.000Z",
			startTime: "18:00:00",
			endTime: "21:00:00",
			link: "https://seattle.aitinkerers.org/p/ai-dev-tool-track-seattle-meetup-april-13th-2026",
			imageUrl: "/uploads/uploadedfiles/event-eff286c3-38c7-41cb-938b-6777b4f7d40c.png",
			location: "1605 Boylston Ave, Seattle, WA 98122",
			hostName: null,
			source: "foundations",
		},
		{
			id: "c11376e3-4393-4e1c-9415-3e8b4d6ac8b9",
			name: "Building for Model Volatility",
			description:
				"The model you shipped on Monday might be obsolete by Friday. How do you build for that? OpenRouter, PostHog and Foundations present Building for Model Volatility - three demo-based talks and a panel with engineers who are actually solving this problem in production.",
			date: "2026-04-16T07:00:00.000Z",
			startTime: "18:30:00",
			endTime: "21:00:00",
			link: "https://luma.com/ujakdk75",
			imageUrl: "/uploads/uploadedfiles/event-c11376e3-4393-4e1c-9415-3e8b4d6ac8b9.png",
			location: "1605 Boylston Ave, Seattle, WA 98122",
			hostName: "Foundations",
			source: "foundations",
		},
	],
};
---

<BaseLayout title="Events - Foundations" description="Upcoming events at Foundations">
	<section class="site-container space-y-10 pb-16 md:space-y-12 md:pb-24">
		<div
			class="overflow-x-clip bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat pt-24 md:pt-32 dark:bg-none"
		>
			<div class="mx-auto flex max-w-[950px] flex-col justify-center">
				<h1 class="h1 text-center">Upcoming Events</h1>
			</div>
		</div>

		<div class="mx-auto max-w-6xl overflow-hidden rounded-2xl border border-primary-200/70 bg-gradient-to-r from-primary-50 via-white to-primary-100/70 shadow-sm dark:border-primary-900/40 dark:from-primary-950/40 dark:via-background dark:to-primary-900/20">
			<div class="flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between sm:p-5">
				<div class="flex items-start gap-3">
					<svg
						class="mt-1 h-12 w-12 shrink-0 text-primary-600 dark:text-primary-400"
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.75"
							d="M7 10V7a5 5 0 0110 0v3m-9 0h8a2 2 0 012 2v5a2 2 0 01-2 2H8a2 2 0 01-2-2v-5a2 2 0 012-2zm4 3v3"
						/>
					</svg>
					<div class="space-y-1">
						<p class="text-sm font-semibold text-foreground">Member-only events</p>
						<p class="text-sm leading-6 text-muted-foreground">
							There are also
							<a
								id="member-only-link"
								href="https://app.fndtns.org/root/calendar"
								target="_blank"
								rel="noopener noreferrer"
								class="font-semibold text-foreground underline decoration-primary-300 underline-offset-4 transition-colors hover:text-primary-700 hover:decoration-primary-500 dark:hover:text-primary-300"
							>
								<span id="member-only-count">2</span>
								<span id="member-only-label">upcoming member-only events</span>
							</a>.
						</p>
					</div>
				</div>
				<a
					href="/membership"
					class="inline-flex w-fit items-center justify-center rounded-full bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-background dark:bg-primary-500 dark:hover:bg-primary-600"
				>
					Apply for membership
				</a>
			</div>
		</div>

		<div id="loading" class="mx-auto max-w-2xl text-center">
			<div class="rounded-lg bg-gray-50 p-8 dark:bg-gray-800/50">
				<div class="mx-auto mb-4 h-12 w-12 animate-spin rounded-full border-4 border-gray-300 border-t-primary-600"></div>
				<p class="text-lg text-gray-600 dark:text-gray-300">Loading events...</p>
			</div>
		</div>

		<div id="error" class="mx-auto max-w-2xl text-center hidden">
			<div class="rounded-lg bg-red-50 p-8 dark:bg-red-900/20">
				<Icon name="tabler/alert-triangle" class="mx-auto mb-4 h-12 w-12 text-red-600 dark:text-red-400" />
				<p class="text-lg text-red-800 dark:text-red-300">Failed to load events</p>
				<p class="mt-2 text-sm text-red-600 dark:text-red-400">Please try again later.</p>
			</div>
		</div>

		<div id="empty" class="mx-auto max-w-2xl text-center hidden">
			<div class="rounded-lg bg-gray-50 p-8 dark:bg-gray-800/50">
				<Icon name="tabler/calendar-check" class="mx-auto mb-4 h-12 w-12 text-gray-400" />
				<p class="text-lg text-gray-600 dark:text-gray-300">No upcoming events at this time.</p>
				<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Check back soon for new events!</p>
			</div>
		</div>

		<div class="mx-auto max-w-6xl">
			<div id="events-container" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3 hidden"></div>
		</div>
	</section>
</BaseLayout>

<script define:vars={{ stagingEventsPayload }}>
	function isProductionHostname() {
		const hostname = window.location.hostname;
		return [
			"fndtns.org",
			"www.fndtns.org",
			"seattlefoundations.org",
			"www.seattlefoundations.org",
		].includes(hostname);
	}

	function escapeHtml(value) {
		return value
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;")
			.replaceAll("'", "&#39;");
	}

	function normalizeText(value) {
		return (value ?? "").replace(/\s+/g, " ").trim();
	}

	function resolveAssetUrl(value) {
		if (!value) return null;
		try {
			return new URL(value, "https://app.fndtns.org").toString();
		} catch {
			return null;
		}
	}

	function formatDate(dateString) {
		const date = new Date(dateString);
		return date.toLocaleDateString("en-US", {
			weekday: "long",
			year: "numeric",
			month: "long",
			day: "numeric",
		});
	}

	function formatTime(time) {
		if (!time) return null;
		const [hours = "0", minutes = "00"] = time.split(":");
		const hour = parseInt(hours, 10);
		const ampm = hour >= 12 ? "PM" : "AM";
		const displayHour = hour % 12 || 12;
		return `${displayHour}:${minutes} ${ampm}`;
	}

	function formatTimeRange(startTime, endTime) {
		const formattedStart = formatTime(startTime);
		const formattedEnd = formatTime(endTime);
		if (formattedStart && formattedEnd) return `${formattedStart} - ${formattedEnd}`;
		if (formattedStart) return formattedStart;
		if (formattedEnd) return formattedEnd;
		return "Time TBD";
	}

	function updatePrivateEventCount(count) {
		const countEl = document.getElementById("member-only-count");
		const labelEl = document.getElementById("member-only-label");
		const normalizedCount = Number.isFinite(count) ? Math.max(0, count) : 0;

		if (countEl) {
			countEl.textContent = String(normalizedCount);
		}

		if (labelEl) {
			labelEl.textContent =
				normalizedCount === 1 ? "upcoming member-only event" : "upcoming member-only events";
		}
	}

	function getMonthDay(dateString) {
		const date = new Date(dateString);
		const month = date.toLocaleDateString("en-US", { month: "short" }).toUpperCase();
		const day = date.getDate().toString();
		return { month, day };
	}

	function getSourceLabel(source) {
		if (!source) return "Event";
		const normalized = source.trim().toLowerCase();
		if (normalized === "foundations") return "Foundations";
		if (normalized === "aitinkerers") return "AI Tinkerers";
		if (normalized === "luma") return "Luma";
		return normalized.charAt(0).toUpperCase() + normalized.slice(1);
	}

	function createEventCard(event) {
		const { month, day } = getMonthDay(event.date);
		const safeName = escapeHtml(normalizeText(event.name));
		const safeDescription = escapeHtml(normalizeText(event.description));
		const safeHostName = escapeHtml(normalizeText(event.hostName));
		const safeLocation = escapeHtml(normalizeText(event.location));
		const safeLink = event.link ? escapeHtml(event.link) : "";
		const sourceLabel = escapeHtml(getSourceLabel(event.source));
		const imageUrl = resolveAssetUrl(event.imageUrl);
		const cardInner = `
			${imageUrl ? `
				<div class="aspect-[16/9] overflow-hidden bg-muted">
					<img
						src="${escapeHtml(imageUrl)}"
						alt="${safeName}"
						loading="lazy"
						class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
					/>
				</div>
			` : ""}
			<div class="flex h-full flex-col gap-5 p-6">
				<div class="flex items-start justify-between gap-4">
					<div class="inline-flex items-center gap-2 rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">
						<span>${sourceLabel}</span>
					</div>
					<div class="flex h-16 w-16 shrink-0 flex-col items-center justify-center rounded-xl bg-primary-100 dark:bg-primary-900/30">
						<span class="text-xs font-semibold text-primary-600 dark:text-primary-400">${month}</span>
						<span class="text-2xl font-bold text-primary-700 dark:text-primary-300">${day}</span>
					</div>
				</div>

				<div class="space-y-3">
					<h2 class="text-xl font-semibold leading-tight text-foreground">
						${safeName}
					</h2>
					<div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
						<div class="flex items-center gap-1">
							<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<span>${formatDate(event.date)}</span>
						</div>
						<div class="flex items-center gap-1">
							<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
							<span>${formatTimeRange(event.startTime, event.endTime)}</span>
						</div>
					</div>
					${safeHostName ? `
						<div class="flex items-start gap-2 text-sm text-muted-foreground">
							<svg class="mt-0.5 h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5V4H2v16h5m10 0v-2a4 4 0 00-4-4H11a4 4 0 00-4 4v2m10 0H7m10-9a4 4 0 11-8 0 4 4 0 018 0z" />
							</svg>
							<span>${safeHostName}</span>
						</div>
					` : ""}
					${safeLocation ? `
						<div class="flex items-start gap-2 text-sm text-muted-foreground">
							<svg class="mt-0.5 h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.243-4.243a8 8 0 1111.313 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
							<span>${safeLocation}</span>
						</div>
					` : ""}
					${safeDescription ? `
						<p class="line-clamp-5 text-sm leading-6 text-muted-foreground">
							${safeDescription}
						</p>
					` : `
						<p class="text-sm leading-6 text-muted-foreground">
							More details will be shared on the registration page.
						</p>
					`}
				</div>

				<div class="mt-auto flex items-center justify-between gap-4 pt-2">
					<span class="text-xs uppercase tracking-wide text-muted-foreground">
						${event.link ? "Open event page" : "Details shared directly"}
					</span>
					${event.link ? `
						<span class="inline-flex items-center gap-2 rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors group-hover:bg-primary-700 dark:bg-primary-500 dark:group-hover:bg-primary-600">
							<span>View event</span>
							<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</span>
					` : `
						<div class="inline-flex items-center rounded-md border border-border px-4 py-2 text-sm font-medium text-muted-foreground">
							Members will receive details directly
						</div>
					`}
				</div>
			</div>
		`;

		return event.link
			? `
				<a
					href="${safeLink}"
					target="_blank"
					rel="noopener noreferrer"
					class="group block overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-background dark:hover:shadow-black/20"
				>
					${cardInner}
				</a>
			`
			: `
				<article class="group overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl dark:hover:shadow-black/20">
					${cardInner}
				</article>
			`;
	}

	function getEventsPayload() {
		if (!isProductionHostname()) {
			return stagingEventsPayload;
		}

		return fetch(`https://app.fndtns.org/api/calendar/events?t=${Date.now()}`, {
			method: "GET",
			headers: {
				Accept: "application/json",
			},
		}).then(async (response) => {
			if (!response.ok) {
				throw new Error(`HTTP error! status: ${response.status}`);
			}

			return await response.json();
		});
	}

	async function loadEvents() {
		const loadingEl = document.getElementById("loading");
		const errorEl = document.getElementById("error");
		const emptyEl = document.getElementById("empty");
		const containerEl = document.getElementById("events-container");

		loadingEl?.classList.remove("hidden");
		errorEl?.classList.add("hidden");
		emptyEl?.classList.add("hidden");
		containerEl?.classList.add("hidden");

		try {
			const data = await getEventsPayload();

			console.log("Events API Response:", {
				success: data.success,
				eventCount: data.events?.length || 0,
				upcomingPrivateEventCount: data.upcomingPrivateEventCount ?? 0,
				events: data.events,
			});

			updatePrivateEventCount(data.upcomingPrivateEventCount ?? 0);

			loadingEl?.classList.add("hidden");

			if (data.success && data.events && data.events.length > 0) {
				const sortedEvents = data.events.sort(
					(a, b) => new Date(a.date).getTime() - new Date(b.date).getTime(),
				);

				const eventsHTML = sortedEvents.map((event) => createEventCard(event)).join("");

				if (containerEl) {
					containerEl.innerHTML = eventsHTML;
					containerEl.classList.remove("hidden");
				}
			} else {
				emptyEl?.classList.remove("hidden");
			}
		} catch (error) {
			console.error("Error fetching events:", error);
			loadingEl?.classList.add("hidden");
			errorEl?.classList.remove("hidden");
		}
	}

	let eventsLoaded = false;

	function checkAndLoadEvents() {
		const isEventsPage = window.location.pathname === "/events" || window.location.pathname === "/events/";
		const hasEventsContainer = document.getElementById("events-container") !== null;

		if (isEventsPage && hasEventsContainer && !eventsLoaded) {
			eventsLoaded = true;
			loadEvents();
		} else if (!isEventsPage) {
			eventsLoaded = false;
		}
	}

	checkAndLoadEvents();

	const observer = new MutationObserver(() => {
		checkAndLoadEvents();
	});

	observer.observe(document.body, {
		childList: true,
		subtree: true,
	});

	document.addEventListener("visibilitychange", () => {
		if (!document.hidden && window.location.pathname.includes("/events")) {
			eventsLoaded = false;
			checkAndLoadEvents();
		}
	});

	window.addEventListener("popstate", () => {
		eventsLoaded = false;
		setTimeout(checkAndLoadEvents, 100);
	});

	document.addEventListener("astro:after-swap", () => {
		eventsLoaded = false;
		checkAndLoadEvents();
	});
</script>