---
// components
import FeatureCard from "@components/FeatureCard/FeatureCardSideImage.astro";

// images
import image1 from "@images/event.jpg";
import image2 from "@images/fir-launch.jpg";

interface FeatureItem {
	badge: string; // badge text
	image: ImageMetadata | string; // an imported image or public asset path
	title: string;
	description?: string[];
	items: string[]; // list of items that will have check marks next to
	closingLine?: string;
	href?: string; // link to learn more
	actionLabel?: string; // button label
	imageClass?: string;
}

const rootHref = "https://app.fndtns.org/root";

// data
const featureData: FeatureItem[] = [
	{
		badge: "Our Space",
		image: image1,
		title: "10,000 sqft space in Capitol Hill",
		items: [
			"24/7 access to a space designed for deep work and collaboration.",
			"50+ seats for members to work in, deep work room, 9 private spaces for meetings.",
			"Weekly community only events.",
			"Event space with 1-2 events every week.",
		],
	},
	{
		badge: "Programming",
		image: image2,
		title: "Founder in Residence Program",
		items: [
			"Weekly office hours with mentors.",
			"Pitch clinics to refine fundraising and sales pitches.",
			"Monthly show & tell events.",
			">$100k of Cloud/AI Credits"
		],
		href: "https://app.fndtns.org/kb/founder-in-residence",
		actionLabel: "Learn More",
	},
	{
		badge: "Root",
		image: "/root-office.jpg",
		title: "Meet Root",
		description: ["Our completely built in-house program manager (yes, we code too) for helping Foundations members navigate the community, unlock resources, and keep momentum."],
		items: [
			"Book office hours and manage mentor sessions.",
			"Find members, events, and helpful community resources.",
			"Tap into the shared knowledge of the Foundations community in one place.",
			"Stay on top of the opportunities, intros, and next steps that matter most.",
		],
		href: rootHref,
		actionLabel: "Explore Root",
	},
];
---

<section id="feature-side-image" class="my-12 overflow-hidden py-12">
	<div class="site-container">
		<!-- <div class="mx-auto mb-16 text-center md:max-w-4xl" data-aos="fade-up">
      <h2 class="h2 mb-4">The best choice for your needs</h2>
    </div> -->
		<div class="mx-auto flex max-w-7xl flex-col gap-16 md:gap-24">
			<FeatureCard
				badge={featureData[0].badge}
				title={featureData[0].title}
				description={featureData[0].description}
				items={featureData[0].items}
				closingLine={featureData[0].closingLine}
				image={featureData[0].image}
				imageClass={featureData[0].imageClass}
				imageSide="right"
				href={featureData[0].href}
				actionLabel={featureData[0].actionLabel ?? "Learn More"}
				idx={0}
			>
				<a
					href="https://fndtns.org/blog/slaying-the-dragon"
					class="group mt-6 flex items-center gap-3 rounded-xl border border-primary-200 bg-primary-50/60 px-4 py-3 no-underline transition-all duration-300 hover:border-primary-300 hover:bg-primary-50 hover:shadow-sm dark:border-primary-800 dark:bg-primary-950/30 dark:hover:border-primary-700 dark:hover:bg-primary-950/50"
				>
					<span class="text-lg">🌉</span>
					<span class="flex flex-col">
						<span class="text-xs font-semibold tracking-wide uppercase text-primary-600 dark:text-primary-400">
							Coming Soon
						</span>
						<span class="text-sm font-medium text-base-800 dark:text-base-200">
							Seattle + San Francisco office expansion
						</span>
					</span>
					<svg
						class="ml-auto size-4 shrink-0 text-primary-400 transition-transform duration-300 group-hover:translate-x-0.5 dark:text-primary-500"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
					</svg>
				</a>
			</FeatureCard>
			{
				featureData.slice(1).map((feature, idx) => (
					<FeatureCard
						badge={feature.badge}
						title={feature.title}
						description={feature.description}
						items={feature.items}
						closingLine={feature.closingLine}
						image={feature.image}
						imageClass={feature.imageClass}
						imageSide={(idx + 1) % 2 === 0 ? "right" : "left"}
						href={feature.href}
						actionLabel={feature.actionLabel ?? "Learn More"}
						idx={idx + 1}
					/>
				))
			}
		</div>
	</div>
</section>
