---
import { getRelativeLocaleUrl } from "astro:i18n";
import { Icon } from "astro-icon/components";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { isActiveNavPath, normalizeNavPath } from "@js/navUtils";

// data
import { type navLinkItem } from "@config/types/configDataTypes";

interface Props {
	navItem: navLinkItem;
	class?: string;
	noIcon?: boolean;
	showSelectedState?: boolean;
}

const { navItem, class: className, noIcon = false, showSelectedState = false } =
	Astro.props as Props;
const { text, link, newTab = false, icon } = navItem;

const currLocale = getLocaleFromUrl(Astro.url);
const currentPath = normalizeNavPath(Astro.url.pathname);

const domain = import.meta.env.SITE; // pulls from astro.config.mjs
let actualLink: string;
if (!link.includes(domain) && !link.startsWith("/") && !link.startsWith("#")) {
	// it is an external link
	actualLink = link;
} else {
	// internal link, so we need to add the locale to the link
	actualLink = getRelativeLocaleUrl(currLocale, link);
}
// remove trailing slash so IDs will work
if (actualLink.endsWith("/") && actualLink !== "/") {
	actualLink = actualLink.slice(0, -1);
}

const isActive =
	showSelectedState &&
	!newTab &&
	!actualLink.startsWith("#") &&
	isActiveNavPath(currentPath, actualLink);
---

<li>
	<a
		class:list={[
			`primary-focus nav__link--base relative flex h-10 w-full items-center gap-1.5 rounded-md px-4 py-2 ${className}`,
			{
				"bg-base-100 text-base-900 dark:bg-base-800 dark:text-base-100": isActive,
			},
		]}
		href={actualLink}
		target={newTab ? "_blank" : ""}
		rel={newTab ? "noopener noreferrer" : ""}
		aria-label={text}
		aria-current={isActive ? "page" : undefined}
	>
		{
			icon && !noIcon && (
				<Icon name={icon} aria-hidden="true" class="mt-1 size-5 self-start md:size-4" />
			)
		}
		{text}
	</a>
</li>
