---
/**
 * * These are alternating side cards with titles, check-marked list items, and images
 */

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getRelativeLocaleUrl } from "astro:i18n";

// components
import Button from "@components/Button/Button.astro";
import Badge from "@components/Badge/Badge.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";

interface Props {
	badge: string; // small badge
	title: string; // larger title
	description?: string[]; // optional supporting paragraphs
	items: string[]; // list of items that will have check marks next to
	closingLine?: string; // optional closing statement after the list
	href?: string; // link to learn more
	actionLabel?: string; // button label
	image: ImageMetadata | string; // an imported image or public asset path
	imageClass?: string; // optional image sizing overrides
	imageSide: "left" | "right";
	idx: number; // determines which "blob" icon svg to use. There are 4 options (0-3)
	rest?: any; // catch-all for any additional parameters, such as "aria-label"
}

const {
	badge,
	image,
	title,
	description = [],
	items,
	closingLine,
	href,
	actionLabel,
	imageClass,
	idx,
	imageSide,
	...rest
} =
	Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
---

<div class="mx-auto grid gap-8 rounded-xl md:grid-cols-2 md:gap-12 lg:gap-20" {...rest}>
	<!-- text -->
	<div class=`${imageSide === "left" ? "md:order-last": ""} col-span-1 flex items-center`>
		<div>
			<Badge>{badge}</Badge>
			<h2 class="h2">{title}</h2>
			{
				description.map((paragraph) => (
					<p class="description mt-4">{paragraph}</p>
				))
			}
			<ul class="mt-6">
				{
					items.map((item) => (
						<li class="description mt-4 flex items-center">
							<Icon
								name="tabler/circle-check"
								class="text-primary-500 mr-2 size-6"
								aria-hidden="true"
							/>
							<span>{item}</span>
						</li>
					))
				}
			</ul>
			{
				closingLine && <p class="description mt-6 font-medium">{closingLine}</p>
			}

		{
			href && (
				<div class="z-20 mt-8 flex">
					<Button
						variant="primary"
						href={href}
						arrow="right"
					>
						{actionLabel}
					</Button>
				</div>
			)
		}

			<slot />
		</div>
	</div>

	<!-- image -->
	<div class="relative mx-auto max-w-4xl">
		<Icon
			name="atlas/circle3"
			class:list={[
				"absolute -top-4 -left-8 z-10 size-20 md:-top-8 md:size-28",
				imageSide === "right" ? "text-accent-1" : "text-accent-4 rotate-90",
			]}
			aria-hidden="true"
		/>
		<Icon
			name="atlas/dots3"
			class:list={[
				"text-accent-2 absolute -right-7 -bottom-4 z-10 h-auto w-20 md:-bottom-8 md:w-28",
				imageSide === "right" ? "text-accent-2" : "text-accent-3",
			]}
			aria-hidden="true"
		/>
		{
			typeof image === "string" ? (
				<img
					class:list={["relative rounded-xl border border-transparent object-cover", imageClass]}
					src={image}
					alt={title}
				/>
			) : (
				<Image
					class:list={["relative rounded-xl border border-transparent object-cover", imageClass]}
					src={image}
					alt={title}
					height={700}
				/>
			)
		}
	</div>
</div>
